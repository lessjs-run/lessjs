#!/bin/sh
#
# openElement pre-commit hook
# Runs formatting, linting, type checking, and autoflow invariant check
# before allowing a commit.
# Install: deno task hooks:install
# Uninstall: deno task hooks:uninstall
#

set -e

echo "Running deno fmt --check (packages/)..."
deno fmt --check packages/

echo "Running deno lint (packages/)..."
deno lint packages/

echo "Running deno check (key entry points)..."
deno check packages/core/src/index.ts \
  packages/rpc/src/index.ts \
  packages/ui/src/index.ts \
  packages/adapter-lit/src/index.ts \
  packages/adapter-lit/src/ssr.ts \
  packages/signals/src/index.ts \
  packages/create/cli.ts

echo ""
echo "Running autoflow:check (governance invariants)..."
deno run --allow-read tools/autoflow/mod-check.ts || {
  echo ""
  echo "❌ autoflow:check failed. Fix the violations below before committing."
  echo "   Run 'deno task autoflow:report' to see current state."
  exit 1
}

echo ""
echo "All pre-commit checks passed."
