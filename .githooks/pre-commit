#!/bin/sh
#
# openElement pre-commit hook
# Runs the same checks as CI before allowing a commit.
# Install: deno task hooks:install
# Uninstall: deno task hooks:uninstall
#
# arch:check is excluded — requires git subprocess not available in Deno sandbox.
# It is still enforced in CI (test.yml).

set -e

echo "[1/6] deno task fmt:check"
deno task fmt:check || { echo "❌ Format check failed."; exit 1; }

echo "[2/6] deno task lint"
deno task lint || { echo "❌ Lint check failed."; exit 1; }

echo "[3/6] deno task graph:check"
deno task graph:check || { echo "❌ Package graph check failed."; exit 1; }

echo "[4/6] deno task docs:check-strategy"
deno task docs:check-strategy || { echo "❌ Strategic docs check failed."; exit 1; }

echo "[5/6] deno task docs:check-current"
deno task docs:check-current || { echo "❌ Current docs check failed."; exit 1; }

echo "[6/6] autoflow:check"
deno run --allow-read tools/autoflow/mod-check.ts || {
  echo "❌ autoflow:check failed."
  exit 1
}

echo ""
echo "All pre-commit checks passed."