#!/bin/sh
#
# openElement pre-commit hook
# autoflow:gate is the single controller — it reads git diff, determines
# the impact surface, runs all required checks, and prints an LLM-facing
# impact report.
#
# Install: deno task hooks:install

set -e

echo "[autoflow:gate] pre-commit"
deno run --allow-read --allow-run --allow-write tools/autoflow/mod-gate.ts --staged || {
  echo ""
  echo "❌ autoflow:gate FAILED. Fix the issues above and retry."
  echo "   The AI assistant is expected to read the impact report"
  echo "   and verify all LLM directives before retrying."
  exit 1
}

echo ""
echo "✅ autoflow:gate PASSED — commit allowed."
