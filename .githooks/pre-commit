#!/bin/sh
#
# openElement pre-commit hook
# Must pass before any commit is allowed.
# Install: deno task hooks:install

set -e

echo "[1/7] deno task fmt:check"
deno task fmt:check || { echo "❌ Format check failed."; exit 1; }

echo "[2/7] deno task lint"
deno task lint || { echo "❌ Lint check failed."; exit 1; }

echo "[3/7] deno check (all 19 packages)"
deno check \
  packages/core/src/index.ts \
  packages/rpc/src/index.ts \
  packages/ui/src/index.ts \
  packages/adapter-lit/src/index.ts \
  packages/adapter-vanilla/src/index.ts \
  packages/adapter-react/src/index.ts \
  packages/adapter-vite/src/index.ts \
  packages/create/cli.ts \
  packages/signals/src/index.ts \
  packages/content/src/index.ts \
  packages/i18n/src/index.ts \
  packages/app/src/index.ts \
  packages/style-sheet/src/index.ts \
  packages/compat-check/src/index.ts \
  packages/cem/src/index.ts \
  packages/protocols/src/index.ts \
  packages/runtime/src/index.ts \
  packages/router/src/mod.ts \
  || { echo "❌ Type check failed."; exit 1; }
echo "   ✅ All 19 packages typecheck"

echo "[4/7] deno task graph:check"
deno task graph:check || { echo "❌ Package graph check failed."; exit 1; }

echo "[5/7] deno task docs:check-strategy"
deno task docs:check-strategy || { echo "❌ Strategic docs check failed."; exit 1; }

echo "[6/7] deno task docs:check-current"
deno task docs:check-current || { echo "❌ Current docs check failed."; exit 1; }

echo "[7/7] autoflow:check"
deno run --allow-read tools/autoflow/mod-check.ts || {
  echo "❌ autoflow:check failed."
  exit 1
}

echo ""
echo "All pre-commit checks passed."