#!/bin/sh
#
# openElement pre-push hook
# autoflow:gate:push is the full gate controller — impact-driven + publish extras.
# Install: deno task hooks:install

set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "dev" ] && [ "$BRANCH" != "main" ]; then
  exit 0
fi

echo "=== pre-push: autoflow:gate for '$BRANCH' ==="

deno run --allow-read --allow-run --allow-write tools/autoflow/mod-gate.ts --push || {
  echo ""
  echo "❌ autoflow:gate FAILED."
  exit 1
}

echo ""
echo "All gates passed."
