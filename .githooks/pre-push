#!/bin/sh
#
# openElement pre-push hook
# Runs the master gate before any push to dev or main.
# Install: deno task hooks:install

set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "dev" ] && [ "$BRANCH" != "main" ]; then
  exit 0
fi

echo "=== pre-push: master gate for '$BRANCH' ==="

deno task gate || { echo "❌ Master gate failed."; exit 1; }

echo ""
echo "All gates passed."
