{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/core",
    "./packages/rpc",
    "./packages/ui",
    "./packages/adapter-lit",
    "./packages/adapter-vanilla",
    "./packages/adapter-react",
    "./packages/adapter-vite",
    "./packages/create",
    "./packages/signals",
    "./packages/content",
    "./packages/i18n",
    "./packages/app",
    "./packages/hub",
    "./packages/style-sheet",
    "./packages/compat-check",
    "./packages/cem",
    "./packages/protocols",
    "./packages/runtime",
    "./packages/router",
    "./packages/ssg",
    "./www"
  ],
  "imports": {
    "@openelement/core": "jsr:@openelement/core@^0.39.0",
    "@openelement/rpc": "jsr:@openelement/rpc@^0.39.0",
    "@openelement/protocols": "jsr:@openelement/protocols@^0.39.0",
    "@openelement/runtime": "jsr:@openelement/runtime@^0.39.0",
    "@openelement/signals": "jsr:@openelement/signals@^0.39.0",
    "@openelement/style-sheet": "jsr:@openelement/style-sheet@^0.39.0",
    "@openelement/compat-check": "jsr:@openelement/compat-check@^0.39.0",
    "@openelement/cem": "jsr:@openelement/cem@^0.39.0",
    "@openelement/ui": "jsr:@openelement/ui@^0.39.0",
    "@openelement/router": "jsr:@openelement/router@^0.39.0",
    "@openelement/ssg": "jsr:@openelement/ssg@^0.39.0",
    "@openelement/adapter-lit": "jsr:@openelement/adapter-lit@^0.39.0",
    "@openelement/adapter-vanilla": "jsr:@openelement/adapter-vanilla@^0.39.0",
    "@openelement/adapter-react": "jsr:@openelement/adapter-react@^0.39.0",
    "@openelement/adapter-vite": "jsr:@openelement/adapter-vite@^0.39.0",
    "@openelement/content": "jsr:@openelement/content@^0.39.0",
    "@openelement/i18n": "jsr:@openelement/i18n@^0.39.0",
    "@openelement/app": "jsr:@openelement/app@^0.39.0",
    "daisyui": "npm:daisyui@^5.5.23",
    "lit": "npm:lit@^3.2.0",
    "@lit/reactive-element": "npm:@lit/reactive-element@^2",
    "lit-element": "npm:lit-element@^4",
    "lit-html": "npm:lit-html@^3",
    "@lit-labs/ssr-dom-shim": "npm:@lit-labs/ssr-dom-shim@^1.5.0",
    "hono": "npm:hono@^4.12",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "alien-signals": "npm:alien-signals@^3.2.0",
    "vite": "npm:vite@8.0.10",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@^3.1.1",
    "@mdx-js/rollup": "npm:@mdx-js/rollup@^3.1.1",
    "typescript": "npm:typescript@^5.9.0",
    "@types/node": "npm:@types/node@^22.0.0",
    "entities": "npm:entities@^4",
    "entities/": "npm:entities@^4/",
    "flexsearch": "npm:flexsearch@0.8.212",
    "@playwright/test": "npm:@playwright/test@1.59.1",
    "ws": "npm:ws@^8.20.1",
    "@shoelace-style/shoelace": "npm:@shoelace-style/shoelace@^2.19",
    "media-chrome": "npm:media-chrome@^4.19",
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "react-dom/server": "npm:react-dom@^19.1.0/server",
    "@types/react": "npm:@types/react@^19.1.0",
    "@types/react-dom": "npm:@types/react-dom@^19.1.0",
    "sanitize-html": "npm:sanitize-html@^2.17.4",
    "@types/sanitize-html": "npm:@types/sanitize-html@^2"
  },
  "vendor": true,
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys npm:vite --config vite.config.ts",
    "dev:fast": "cd www && deno run --allow-read --allow-net --allow-env --allow-ffi --allow-sys --config ../deno.json app/dev-server.ts",
    "build": "cd www && deno run --config ../deno.json --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys --allow-run ../packages/adapter-vite/src/cli/build.ts",
    "preview": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi npm:vite preview --config vite.config.ts",
    "build:docs": "deno task build",
    "hub:scan": "deno run --allow-read --allow-write=hub-index,www/public/hub,www/app/data/registry,www/app/routes/registry --allow-net=cdn.jsdelivr.net,esm.sh,unpkg.com,registry.npmjs.org,localhost,127.0.0.1 --allow-env=LESS_CDN_BASE,DENO_DIR --allow-run packages/hub/scan.ts",
    "hub:validate": "deno run --allow-read packages/hub/src/cli/validate.ts",
    "hub:check-index": "deno run --allow-read packages/hub/src/cli/check-index.ts",
    "hub:index:update": "deno run --allow-read --allow-write packages/hub/src/cli/update-index.ts",
    "dsd:check-report": "deno run --allow-read --allow-env packages/hub/src/cli/dsd-report-gate.ts",
    "workflow:check": "deno run --allow-read tools/check-project-workflow.ts",
    "workflow:check-slimming": "deno run --allow-read tools/check-workflow-slimming.ts",
    "docs:check-public": "deno run --allow-read tools/check-public-docs-integrity.ts",
    "docs:check-strategy": "deno run --allow-read tools/check-strategic-docs.ts",
    "docs:check-current": "deno run --allow-read tools/check-current-docs-no-legacy.ts",
    "ci:check-package-tests": "deno run --allow-read tools/check-ci-package-tests.ts",
    "package-surface:check": "deno run --allow-read tools/check-package-surface.ts",
    "signals:check-protocol-boundary": "deno run --allow-read tools/check-signal-protocol-boundary.ts",
    "arch:check": "deno run --allow-read --allow-run tools/check-architecture-contract.ts",
    "dist:check-object-object": "deno run --allow-read tools/check-dist-no-object-object.ts",
    "graph:check": "deno run --allow-read tools/check-package-graph.ts",
    "graph:check-imports": "deno run --allow-read --allow-write --allow-run tools/check-import-map.ts",
    "consumer:local": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net tools/consumer-local.ts",
    "publish:core": "cd packages/core && deno publish",
    "publish:rpc": "cd packages/rpc && deno publish",
    "publish:protocols": "cd packages/protocols && deno publish",
    "publish:router": "cd packages/router && deno publish",
    "publish:style-sheet": "cd packages/style-sheet && deno publish",
    "publish:runtime": "cd packages/runtime && deno publish",
    "publish:cem": "cd packages/cem && deno publish",
    "publish:compat-check": "cd packages/compat-check && deno publish",
    "publish:ui": "cd packages/ui && deno publish",
    "publish:adapter-lit": "cd packages/adapter-lit && deno publish",
    "publish:adapter-vanilla": "cd packages/adapter-vanilla && deno publish",
    "publish:adapter-react": "cd packages/adapter-react && deno publish",
    "publish:create": "cd packages/create && deno publish",
    "publish:signals": "cd packages/signals && deno publish",
    "publish:content": "cd packages/content && deno publish",
    "publish:i18n": "cd packages/i18n && deno publish",
    "publish:adapter-vite": "cd packages/adapter-vite && deno publish",
    "publish:app": "cd packages/app && deno publish",
    "publish:hub": "cd packages/hub && deno publish",
    "publish:ssg": "cd packages/ssg && deno publish",
    "publish": "deno audit && deno task typecheck && deno task lint && deno task fmt:check && deno task test && deno task build && deno run --allow-read --allow-run --allow-net tools/run-package-graph-task.ts publish",
    "publish:dry-run": "deno run --allow-read --allow-run tools/run-package-graph-task.ts publish:dry-run",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "test:coverage": "deno test --coverage=.coverage --allow-read --allow-write --allow-env --allow-net --allow-run && deno coverage .coverage --lcov > .coverage/lcov.info",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --watch",
    "test:e2e": "deno run -A npm:@playwright/test@1.59.1 test --config www/e2e/playwright.config.ts --project=chromium",
    "test:e2e:browsers": "deno run -A npm:@playwright/test@1.59.1 test --config www/e2e/playwright.config.ts",
    "test:e2e:install": "deno run -A npm:playwright@1.59.1 install chromium",
    "test:e2e:browsers:install": "deno run -A npm:playwright@1.59.1 install chromium firefox webkit",
    "nitro:proof:node": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net tools/nitro-proof.ts node",
    "nitro:proof:workers": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net tools/nitro-proof.ts workers",
    "test:coverage:check": "deno run --allow-read --allow-run --allow-write --allow-env --allow-net tools/check-coverage.ts --threshold 50",
    "consumer:core-smoke": "deno run -A tools/consumer-smoke.ts --local",
    "typecheck": "deno run --allow-read --allow-run tools/run-package-graph-task.ts typecheck",
    "lint": "deno lint",
    "fmt": "deno fmt --ignore=deliverables/,www/content/blog/,www/app/routes/,www/app/data/,docs/mockups/,docs/conversation/,custom-dist/,dist-test-ssg-render/,dist-test-ssg-package-render/,.deno_cache/",
    "fmt:check": "deno fmt --check --ignore=deliverables/,www/content/blog/,www/app/routes/,www/app/data/,docs/mockups/,docs/conversation/,custom-dist/,dist-test-ssg-render/,dist-test-ssg-package-render/,.deno_cache/",
    "clean": "rm -rf packages/*/dist www/dist",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config core.hooksPath",
    "autoflow:report": "deno run --allow-read tools/autoflow/mod.ts",
    "autoflow:report:json": "deno run --allow-read tools/autoflow/mod.ts --json",
    "autoflow:check": "deno run --allow-read --allow-write tools/autoflow/mod-check.ts",
    "autoflow:check-dev": "deno run --allow-read --allow-write tools/autoflow/mod-check.ts --dev",
    "autoflow:check:strict": "deno run --allow-read --allow-write tools/autoflow/mod-check.ts --strict",
    "autoflow:health": "deno run --allow-read tools/autoflow/mod-health.ts",
    "autoflow:health:json": "deno run --allow-read tools/autoflow/mod-health.ts --json",
    "autoflow:dev": "deno run --allow-read --allow-run tools/autoflow/mod3.ts dev",
    "autoflow:push": "deno run --allow-read --allow-run tools/autoflow/mod3.ts push",
    "autoflow:ci": "deno run --allow-read --allow-run tools/autoflow/mod3.ts ci",
    "autoflow:patch-release": "deno run --allow-read --allow-run tools/autoflow/mod3.ts patch-release",
    "autoflow:minor-plan": "deno run --allow-read --allow-run tools/autoflow/mod3.ts minor-plan",
    "autoflow:release": "deno run --allow-read --allow-run tools/autoflow/mod3.ts release",
    "autoflow:evolve": "deno run --allow-read --allow-write --allow-run tools/autoflow/mod-evolve.ts",
    "autoflow:evolve:dry": "deno run --allow-read tools/autoflow/mod-evolve.ts --dry-run",
    "autoflow:test": "deno test --allow-read --allow-write --allow-run tools/autoflow/__tests__/",
    "verify:configs": "deno run --allow-read tools/verify-package-configs.ts",
    "verify:configs:fix": "deno run --allow-read --allow-write tools/verify-package-configs.ts --fix",
    "autoflow:gate": "deno task autoflow:dev",
    "autoflow:gate:push": "deno task autoflow:push",
    "gate": "deno task autoflow:push",
    "gate:full": "deno task autoflow:ci && deno task test:e2e"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "exclude": [
      "deliverables/",
      "www/content/blog/",
      "www/app/routes/",
      "www/app/data/",
      "docs/mockups/",
      "docs/conversation/",
      "custom-dist/",
      "dist-test-ssg-render/",
      ".deno_cache/"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    },
    "exclude": [
      "deliverables/",
      "www/content/blog/",
      "www/app/routes/",
      "www/app/data/",
      "docs/mockups/",
      "docs/conversation/",
      "custom-dist/",
      "dist-test-ssg-render/",
      ".deno_cache/"
    ]
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@openelement/core"
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno",
    ".deno_cache",
    "custom-dist",
    "dist-test-ssg-render",
    "deliverables",
    "vendor"
  ]
}
