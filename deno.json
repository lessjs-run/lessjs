{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/core",
    "./packages/rpc",
    "./packages/ui",
    "./packages/adapter-lit",
    "./packages/create",
    "./packages/signals"
  ],
  "imports": {
    "lit": "npm:lit@^3.2.0",
    "@lit/reactive-element": "npm:@lit/reactive-element@^2",
    "lit-element": "npm:lit-element@^4",
    "lit-html": "npm:lit-html@^3",
    "@lit-labs/ssr-dom-shim": "npm:@lit-labs/ssr-dom-shim@^1.5.0",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10",
    "typescript": "npm:typescript@^5.9.0",
    "tsx": "npm:tsx@^4.21.0",
    "@types/node": "npm:@types/node@^22.0.0",
    "parse5": "npm:parse5@7.0.0",
    "entities": "npm:entities@6.0.0"
  },
  "vendor": true,
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "deno run -A npm:vite docs --config docs/vite.config.ts",
    "build": "cd docs && deno run --config ../deno.json -A ../packages/core/src/cli/build.ts",
    "preview": "deno run -A npm:vite preview docs --config docs/vite.config.ts",
    "build:docs": "deno task build",
    "build:client": "cd docs && deno run --config ../deno.json -A ../packages/core/src/cli/build-client.ts",
    "build:ssg": "cd docs && deno run --config ../deno.json -A ../packages/core/src/cli/build-ssg.ts",
    "publish:core": "cd packages/core && deno publish --allow-dirty",
    "publish:rpc": "cd packages/rpc && deno publish --allow-dirty",
    "publish:ui": "cd packages/ui && deno publish --allow-dirty",
    "publish:adapter-lit": "cd packages/adapter-lit && deno publish --allow-dirty",
    "publish:create": "cd packages/create && deno publish --allow-dirty",
    "publish:signals": "cd packages/signals && deno publish --allow-dirty",
    "publish": "deno task publish:rpc && deno task publish:ui && deno task publish:adapter-lit && deno task publish:signals && deno task publish:core && deno task publish:create",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --watch",
    "typecheck": "deno check **/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "clean": "rm -rf packages/*/dist docs/dist docs/.less"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    }
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno",
    "vendor"
  ]
}
