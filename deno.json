{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/core",
    "./packages/rpc",
    "./packages/ui",
    "./packages/adapter-lit",
    "./packages/adapter-vanilla",
    "./packages/adapter-react",
    "./packages/adapter-vite",
    "./packages/create",
    "./packages/signals",
    "./packages/content",
    "./packages/i18n",
    "./packages/app",
    "./packages/hub",
    "./packages/style-sheet",
    "./packages/compat-check",
    "./packages/cem",
    "./packages/protocols",
    "./packages/runtime",
    "./packages/router",
    "./www"
  ],
  "imports": {
    "@lessjs/core": "./packages/core/src/index.ts",
    "@lessjs/core/context": "./packages/core/src/context.ts",
    "@lessjs/core/errors": "./packages/core/src/errors.ts",
    "@lessjs/core/api": "./packages/core/src/api.ts",
    "@lessjs/core/isr": "./packages/core/src/isr.ts",
    "@lessjs/core/logger": "./packages/core/src/logger.ts",
    "@lessjs/core/types": "./packages/core/src/types.ts",
    "@lessjs/core/jsx-runtime": "./packages/core/src/jsx-runtime.ts",
    "@lessjs/core/jsx-dev-runtime": "./packages/core/src/jsx-runtime.ts",
    "@lessjs/core/signal-context": "./packages/core/src/signal-context.ts",
    "@lessjs/rpc": "./packages/rpc/src/index.ts",
    "@lessjs/protocols": "./packages/protocols/src/index.ts",
    "@lessjs/protocols/build-types": "./packages/protocols/src/build-types.ts",
    "@lessjs/protocols/validators": "./packages/protocols/src/validators.ts",
    "@lessjs/runtime": "./packages/runtime/src/index.ts",
    "@lessjs/signals": "./packages/signals/src/index.ts",
    "@lessjs/signals/framework": "./packages/signals/src/framework.ts",
    "@lessjs/style-sheet": "./packages/style-sheet/src/index.ts",
    "@lessjs/compat-check": "./packages/compat-check/src/index.ts",
    "@lessjs/cem": "./packages/cem/src/index.ts",
    "@lessjs/cem/types": "./packages/cem/src/types.ts",
    "@lessjs/ui": "./packages/ui/src/index.ts",
    // Explicit subpath entries required - Vite alias prefix-matching
    // cannot handle subpath exports from a file-based alias (ENOTDIR).
    "@lessjs/ui/less-button": "./packages/ui/src/less-button.tsx",
    "@lessjs/ui/less-card": "./packages/ui/src/less-card.tsx",
    "@lessjs/ui/less-code-block": "./packages/ui/src/less-code-block.tsx",
    "@lessjs/ui/less-dialog": "./packages/ui/src/less-dialog.tsx",
    "@lessjs/ui/less-hero-ping": "./packages/ui/src/less-hero-ping.tsx",
    "@lessjs/ui/less-input": "./packages/ui/src/less-input.tsx",
    "@lessjs/ui/less-layout": "./packages/ui/src/less-layout.tsx",
    "@lessjs/ui/less-theme-toggle": "./packages/ui/src/less-theme-toggle.tsx",
    "@lessjs/ui/less-callout": "./packages/ui/src/less-callout.tsx",
    "@lessjs/ui/less-step-card": "./packages/ui/src/less-step-card.tsx",
    "@lessjs/ui/open-props-tokens": "./packages/ui/src/open-props-tokens.ts",
    "@lessjs/router": "./packages/router/src/mod.ts",
    "@lessjs/router/define-routes": "./packages/router/src/define-routes.ts",
    "@lessjs/router/pattern-translate": "./packages/router/src/pattern-translate.ts",
    "@lessjs/router/client-router": "./packages/router/src/client-router.ts",
    "@lessjs/router/page-loader": "./packages/router/src/page-loader.ts",
    "@lessjs/adapter-lit": "./packages/adapter-lit/src/index.ts",
    "@lessjs/adapter-lit/ssr": "./packages/adapter-lit/src/ssr.ts",
    "@lessjs/adapter-vanilla": "./packages/adapter-vanilla/src/index.ts",
    "@lessjs/adapter-vanilla/ssr": "./packages/adapter-vanilla/src/ssr.ts",
    "@lessjs/adapter-react": "./packages/adapter-react/src/index.ts",
    "@lessjs/adapter-react/ssr": "./packages/adapter-react/src/ssr.ts",
    "@lessjs/adapter-vite": "./packages/adapter-vite/src/index.ts",
    "@lessjs/adapter-vite/build-context": "./packages/adapter-vite/src/build-context.ts",
    "@lessjs/adapter-vite/plugin-mdx": "./packages/adapter-vite/src/plugin-mdx.ts",
    "@lessjs/content": "./packages/content/src/index.ts",
    "@lessjs/content/mdx": "./packages/content/src/mdx/index.ts",
    "@lessjs/content/sitemap": "./packages/content/src/sitemap/index.ts",
    "@lessjs/i18n": "./packages/i18n/src/index.ts",
    "@lessjs/app": "./packages/app/src/index.ts",
    "happy-dom": "npm:happy-dom@^20.8.9",
    "lit": "npm:lit@^3.2.0",
    "@lit/reactive-element": "npm:@lit/reactive-element@^2",
    "lit-element": "npm:lit-element@^4",
    "lit-html": "npm:lit-html@^3",
    "@lit-labs/ssr-dom-shim": "npm:@lit-labs/ssr-dom-shim@^1.5.0",
    "hono": "npm:hono@4.12.23",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "alien-signals": "npm:alien-signals@^3.2.0",
    "vite": "npm:vite@8.0.10",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@^3.1.1",
    "@mdx-js/rollup": "npm:@mdx-js/rollup@^3.1.1",
    "typescript": "npm:typescript@^5.9.0",
    "@types/node": "npm:@types/node@^22.0.0",
    "entities": "npm:entities@^4",
    "entities/": "npm:entities@^4/",
    "flexsearch": "npm:flexsearch@0.8.212",
    "@playwright/test": "npm:@playwright/test@1.59.1",
    "ws": "npm:ws@^8.20.1",
    "@shoelace-style/shoelace": "npm:@shoelace-style/shoelace@^2.19",
    "media-chrome": "npm:media-chrome@^4.19",
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "react-dom/server": "npm:react-dom@^19.1.0/server",
    "@types/react": "npm:@types/react@^19.1.0",
    "@types/react-dom": "npm:@types/react-dom@^19.1.0"
  },
  "vendor": true,
  "nodeModulesDir": "manual",
  "tasks": {
    // H-18 fix: Use least-privilege permissions instead of -A (all)
    // Note: --allow-ffi is required for rolldown native bindings (.node files)
    // Must cd into www/ so process.cwd() matches Vite root for route scanning
    "dev": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys npm:vite --config vite.config.ts",
    "dev:fast": "cd www && deno run --allow-read --allow-net --allow-env --allow-ffi --allow-sys --config ../deno.json app/dev-server.ts",
    "build": "cd www && deno run --config ../deno.json --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys --allow-run ../packages/adapter-vite/src/cli/build.ts",
    "preview": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi npm:vite preview --config vite.config.ts",
    "build:docs": "deno task build",
    "hub:scan": "deno run --allow-read --allow-write=hub-index,www/public/hub,www/app/data/registry,www/app/routes/registry --allow-net=cdn.jsdelivr.net,esm.sh,unpkg.com,registry.npmjs.org,localhost,127.0.0.1 --allow-env=LESS_CDN_BASE,DENO_DIR --allow-run packages/hub/scan.ts",
    "hub:validate": "deno run --allow-read packages/hub/src/cli/validate.ts",
    "hub:check-index": "deno run --allow-read packages/hub/src/cli/check-index.ts",
    "hub:index:update": "deno run --allow-read --allow-write packages/hub/src/cli/update-index.ts",
    "dsd:check-report": "deno run --allow-read --allow-env packages/hub/src/cli/dsd-report-gate.ts",
    "docs:check-strategy": "deno run --allow-read tools/check-strategic-docs.ts",
    "docs:check-current": "deno run --allow-read tools/check-current-docs-no-legacy.ts",
    "dist:check-object-object": "deno run --allow-read tools/check-dist-no-object-object.ts",
    "graph:check": "deno run --allow-read tools/check-package-graph.ts",
    "graph:check-imports": "deno run --allow-read --allow-write --allow-run tools/check-import-map.ts",
    "consumer:local": "deno run --allow-read --allow-write --allow-run tools/consumer-local.ts",
    "publish:core": "cd packages/core && deno publish",
    "publish:rpc": "cd packages/rpc && deno publish",
    "publish:protocols": "cd packages/protocols && deno publish",
    "publish:router": "cd packages/router && deno publish",
    "publish:style-sheet": "cd packages/style-sheet && deno publish",
    "publish:runtime": "cd packages/runtime && deno publish",
    "publish:cem": "cd packages/cem && deno publish",
    "publish:compat-check": "cd packages/compat-check && deno publish",
    "publish:ui": "cd packages/ui && deno publish",
    "publish:adapter-lit": "cd packages/adapter-lit && deno publish",
    "publish:adapter-vanilla": "cd packages/adapter-vanilla && deno publish",
    "publish:adapter-react": "cd packages/adapter-react && deno publish",
    "publish:create": "cd packages/create && deno publish",
    "publish:signals": "cd packages/signals && deno publish",
    "publish:content": "cd packages/content && deno publish",
    "publish:i18n": "cd packages/i18n && deno publish",
    "publish:adapter-vite": "cd packages/adapter-vite && deno publish",
    "publish:app": "cd packages/app && deno publish",
    "publish:hub": "cd packages/hub && deno publish",
    "publish": "deno audit && deno task typecheck && deno task lint && deno task fmt:check && deno task test && deno task build && deno task publish:rpc && deno task publish:protocols && deno task publish:router && deno task publish:style-sheet && deno task publish:create && deno task publish:signals && deno task publish:core && deno task publish:runtime && deno task publish:cem && deno task publish:compat-check && deno task publish:content && deno task publish:i18n && deno task publish:adapter-lit && deno task publish:adapter-react && deno task publish:adapter-vanilla && deno task publish:adapter-vite && deno task publish:ui && deno task publish:hub && deno task publish:app",
    "publish:dry-run": "deno task publish:rpc --dry-run && deno task publish:protocols --dry-run && deno task publish:router --dry-run && deno task publish:style-sheet --dry-run && deno task publish:create --dry-run && deno task publish:signals --dry-run && deno task publish:core --dry-run && deno task publish:runtime --dry-run && deno task publish:cem --dry-run && deno task publish:compat-check --dry-run && deno task publish:content --dry-run && deno task publish:i18n --dry-run && deno task publish:adapter-lit --dry-run && deno task publish:adapter-react --dry-run && deno task publish:adapter-vanilla --dry-run && deno task publish:adapter-vite --dry-run && deno task publish:ui --dry-run && deno task publish:hub --dry-run && deno task publish:app --dry-run",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "test:coverage": "deno test --coverage=.coverage --allow-read --allow-write --allow-env --allow-net --allow-run && deno coverage .coverage --lcov > .coverage/lcov.info",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --watch",
    "test:e2e": "deno run -A npm:@playwright/test@1.59.1 test --config www/e2e/playwright.config.ts",
    "test:e2e:install": "deno run -A npm:playwright@1.59.1 install chromium",
    "typecheck": "deno check packages/rpc/src/index.ts packages/protocols/src/index.ts packages/protocols/src/build-types.ts packages/protocols/src/validators.ts packages/router/src/mod.ts packages/router/src/define-routes.ts packages/router/src/pattern-translate.ts packages/router/src/client-router.ts packages/router/src/page-loader.ts packages/style-sheet/src/index.ts packages/create/cli.ts packages/signals/src/index.ts packages/core/src/index.ts packages/core/src/api.ts packages/core/src/isr.ts packages/runtime/src/index.ts packages/cem/src/index.ts packages/cem/src/types.ts packages/compat-check/src/index.ts packages/content/src/index.ts packages/i18n/src/index.ts packages/adapter-lit/src/index.ts packages/adapter-lit/src/ssr.ts packages/adapter-vanilla/src/index.ts packages/adapter-vanilla/src/ssr.ts packages/adapter-react/src/index.ts packages/adapter-react/src/ssr.ts packages/adapter-vite/src/index.ts packages/adapter-vite/src/cli/build.ts packages/adapter-vite/src/cli/build-client.ts packages/adapter-vite/src/cli/build-ssg.ts packages/ui/src/index.ts packages/hub/mod.ts packages/hub/src/schema.ts packages/hub/src/builder.ts packages/hub/src/indexer.ts packages/hub/src/submitter.ts packages/hub/src/snapshot.ts packages/hub/src/scanner.ts packages/hub/src/cli/validate.ts packages/hub/src/cli/check-index.ts packages/hub/src/cli/update-index.ts packages/hub/src/cli/less-install-guide.ts packages/app/src/index.ts www/vite.config.ts www/e2e/playwright.config.ts",
    "lint": "deno lint",
    "fmt": "deno fmt --ignore=deliverables/,www/content/blog/,www/app/routes/,www/app/data/,docs/mockups/,docs/conversation/,custom-dist/,dist-test-ssg-render/,.deno_cache/",
    "fmt:check": "deno fmt --check --ignore=deliverables/,www/content/blog/,www/app/routes/,www/app/data/,docs/mockups/,docs/conversation/,custom-dist/,dist-test-ssg-render/,.deno_cache/",
    "clean": "rm -rf packages/*/dist www/dist",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config core.hooksPath"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "exclude": [
      "deliverables/",
      "www/content/blog/",
      "www/app/routes/",
      "www/app/data/",
      "docs/mockups/",
      "docs/conversation/",
      "custom-dist/",
      "dist-test-ssg-render/",
      ".deno_cache/"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    },
    "exclude": [
      "deliverables/",
      "www/content/blog/",
      "www/app/routes/",
      "www/app/data/",
      "docs/mockups/",
      "docs/conversation/",
      "custom-dist/",
      "dist-test-ssg-render/",
      ".deno_cache/"
    ]
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@lessjs/core"
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno",
    ".deno_cache",
    "custom-dist",
    "dist-test-ssg-render",
    "deliverables",
    "vendor"
  ]
}
