{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/core",
    "./packages/rpc",
    "./packages/ui",
    "./packages/adapter-lit",
    "./packages/adapter-vanilla",
    "./packages/adapter-react",
    "./packages/adapter-vite",
    "./packages/create",
    "./packages/signals",
    "./packages/content",
    "./packages/i18n",
    "./packages/app",
    "./www"
  ],
  "imports": {
    "@lessjs/core": "./packages/core/src/index.ts",
    "@lessjs/core/context": "./packages/core/src/context.ts",
    "@lessjs/core/errors": "./packages/core/src/errors.ts",
    "@lessjs/core/logger": "./packages/core/src/logger.ts",
    "@lessjs/core/navigation": "./packages/core/src/navigation.ts",
    "@lessjs/rpc": "./packages/rpc/src/index.ts",
    "@lessjs/signals": "./packages/signals/src/index.ts",
    "@lessjs/ui": "./packages/ui/src/index.ts",
    // rolldown does not support subpath imports from a file:// mapping (ENOTDIR).
    // Explicit subpath entries required for each component used in routes/islands.
    "@lessjs/ui/design-tokens": "./packages/ui/src/design-tokens.ts",
    "@lessjs/ui/less-button": "./packages/ui/src/less-button.ts",
    "@lessjs/ui/less-card": "./packages/ui/src/less-card.ts",
    "@lessjs/ui/less-code-block": "./packages/ui/src/less-code-block.ts",
    "@lessjs/ui/less-dialog": "./packages/ui/src/less-dialog.ts",
    "@lessjs/ui/less-hero-ping": "./packages/ui/src/less-hero-ping.ts",
    "@lessjs/ui/less-input": "./packages/ui/src/less-input.ts",
    "@lessjs/ui/less-layout": "./packages/ui/src/less-layout.ts",
    "@lessjs/ui/less-theme-toggle": "./packages/ui/src/less-theme-toggle.ts",
    "@lessjs/ui/tokens/color-values": "./packages/ui/src/tokens/color-values.ts",
    "@lessjs/ui/tokens/colors": "./packages/ui/src/tokens/colors.ts",
    "@lessjs/adapter-lit": "./packages/adapter-lit/src/index.ts",
    "@lessjs/adapter-vanilla": "./packages/adapter-vanilla/src/index.ts",
    "@lessjs/adapter-react": "./packages/adapter-react/src/index.ts",
    "@lessjs/adapter-vite": "./packages/adapter-vite/src/index.ts",
    "@lessjs/adapter-vite/build-context": "./packages/adapter-vite/src/build-context.ts",
    "@lessjs/adapter-vite/virtual-ids": "./packages/adapter-vite/src/virtual-ids.ts",
    "@lessjs/content": "./packages/content/src/index.ts",
    "@lessjs/content/sitemap": "./packages/content/src/sitemap/index.ts",
    "@lessjs/i18n": "./packages/i18n/src/index.ts",
    "@lessjs/app": "./packages/app/src/index.ts",
    "lit": "npm:lit@^3.2.0",
    "@lit/reactive-element": "npm:@lit/reactive-element@^2",
    "lit-element": "npm:lit-element@^4",
    "lit-html": "npm:lit-html@^3",
    "@lit-labs/ssr-dom-shim": "npm:@lit-labs/ssr-dom-shim@^1.5.0",
    "hono": "npm:hono@^4.12.18",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10",
    "typescript": "npm:typescript@^5.9.0",
    "@types/node": "npm:@types/node@^22.0.0",
    "parse5": "npm:parse5@7.0.0",
    "entities": "npm:entities@^4",
    "flexsearch": "npm:flexsearch@0.8.212",
    "@playwright/test": "npm:@playwright/test@1.59.1",
    "@shoelace-style/shoelace": "npm:@shoelace-style/shoelace@^2.19",
    "media-chrome": "npm:media-chrome@^4.19",
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "react-dom/server": "npm:react-dom@^19.1.0/server",
    "@types/react": "npm:@types/react@^19.1.0",
    "@types/react-dom": "npm:@types/react-dom@^19.1.0"
  },
  "vendor": true,
  "nodeModulesDir": "manual",
  "tasks": {
    // H-18 fix: Use least-privilege permissions instead of -A (all)
    // Note: --allow-ffi is required for rolldown native bindings (.node files)
    // Must cd into www/ so process.cwd() matches Vite root for route scanning
    "dev": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys npm:vite --config vite.config.ts",
    "build": "cd www && deno run --config ../deno.json --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-sys ../packages/adapter-vite/src/cli/build.ts",
    "preview": "cd www && deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi npm:vite preview --config vite.config.ts",
    "build:docs": "deno task build",
    "publish:core": "cd packages/core && deno publish",
    "publish:rpc": "cd packages/rpc && deno publish",
    "publish:ui": "cd packages/ui && deno publish",
    "publish:adapter-lit": "cd packages/adapter-lit && deno publish",
    "publish:adapter-vanilla": "cd packages/adapter-vanilla && deno publish",
    "publish:adapter-react": "cd packages/adapter-react && deno publish",
    "publish:create": "cd packages/create && deno publish",
    "publish:signals": "cd packages/signals && deno publish",
    "publish:content": "cd packages/content && deno publish",
    "publish:i18n": "cd packages/i18n && deno publish",
    "publish:adapter-vite": "cd packages/adapter-vite && deno publish",
    "publish:app": "cd packages/app && deno publish",
    "publish": "deno audit && deno task typecheck && deno task lint && deno task fmt:check && deno task test && deno task build && deno task publish:rpc && deno task publish:signals && deno task publish:core && deno task publish:adapter-vite && deno task publish:content && deno task publish:i18n && deno task publish:adapter-lit && deno task publish:adapter-vanilla && deno task publish:adapter-react && deno task publish:ui && deno task publish:app && deno task publish:create",
    "publish:dry-run": "deno task publish:rpc --dry-run && deno task publish:signals --dry-run && deno task publish:core --dry-run && deno task publish:adapter-vite --dry-run && deno task publish:content --dry-run && deno task publish:i18n --dry-run && deno task publish:adapter-lit --dry-run && deno task publish:adapter-vanilla --dry-run && deno task publish:adapter-react --dry-run && deno task publish:ui --dry-run && deno task publish:app --dry-run && deno task publish:create --dry-run",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "test:coverage": "deno test --coverage=.coverage --allow-read --allow-write --allow-env --allow-net --allow-run && deno coverage .coverage --lcov > .coverage/lcov.info",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --watch",
    "test:e2e": "deno run -A npm:@playwright/test@1.59.1 test --config www/e2e/playwright.config.ts",
    "test:e2e:install": "npx -y playwright@1.59.1 install chromium",
    "typecheck": "deno check packages/core/src/index.ts packages/rpc/src/index.ts packages/ui/src/index.ts packages/adapter-lit/src/index.ts packages/adapter-lit/src/ssr.ts packages/adapter-vanilla/src/index.ts packages/adapter-vanilla/src/ssr.ts packages/adapter-react/src/index.ts packages/adapter-react/src/ssr.ts packages/adapter-vite/src/index.ts packages/adapter-vite/src/cli/build.ts packages/adapter-vite/src/cli/build-client.ts packages/adapter-vite/src/cli/build-ssg.ts packages/signals/src/index.ts packages/create/cli.ts packages/app/src/index.ts packages/i18n/src/index.ts packages/content/src/index.ts www/vite.config.ts www/e2e/playwright.config.ts",
    "lint": "deno lint",
    "fmt": "deno fmt --ignore=deliverables/,www/content/blog/,www/app/routes/,custom-dist/,dist-test-ssg-render/",
    "fmt:check": "deno fmt --check --ignore=deliverables/,www/content/blog/,www/app/routes/,custom-dist/,dist-test-ssg-render/",
    "clean": "rm -rf packages/*/dist www/dist",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config core.hooksPath"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "exclude": [
      "deliverables/",
      "www/content/blog/",
      "custom-dist/",
      "dist-test-ssg-render/"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    }
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno",
    "custom-dist",
    "dist-test-ssg-render",
    "deliverables",
    "vendor"
  ]
}
