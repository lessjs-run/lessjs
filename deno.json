{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/kiss-core",
    "./packages/kiss-rpc",
    "./packages/kiss-ui",
    "./packages/create-kiss",
    "./docs"
  ],
  "imports": {
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0",
    "typescript": "npm:typescript@^5.9.0"
  },
  "tasks": {
    "dev": "cd docs && deno task dev",
    "build:core": "cd packages/kiss-core && deno task build",
    "build:rpc": "cd packages/kiss-rpc && deno task build",
    "build:ui": "cd packages/kiss-ui && deno task build",
    "build": "deno task build:rpc && deno task build:core && deno task build:ui && deno task build:client && deno task build:ssg",
    "build:client": "deno run -A packages/kiss-core/src/cli/build-client.ts",
    "build:ssg": "deno run -A packages/kiss-core/src/cli/build-ssg.ts",
    "docs:build": "cd docs && deno task build",
    "docs:preview": "cd docs && deno task preview",
    "publish:core": "cd packages/kiss-core && deno publish --allow-dirty",
    "publish:rpc": "cd packages/kiss-rpc && deno publish --allow-dirty",
    "publish:ui": "cd packages/kiss-ui && deno task build && deno publish --allow-dirty",
    "publish": "deno task publish:rpc && deno task publish:ui && deno task publish:core",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --watch",
    "typecheck": "deno check **/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno"
  ]
}
