{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "workspace": [
    "./packages/core",
    "./packages/rpc",
    "./packages/ui",
    "./packages/adapter-lit",
    "./packages/adapter-vite",
    "./packages/create",
    "./packages/signals",
    "./packages/content",
    "./packages/i18n",
    "./packages/app",
    "./www"
  ],
  "imports": {
    "lit": "npm:lit@^3.2.0",
    "@lit/reactive-element": "npm:@lit/reactive-element@^2",
    "lit-element": "npm:lit-element@^4",
    "lit-html": "npm:lit-html@^3",
    "@lit-labs/ssr-dom-shim": "npm:@lit-labs/ssr-dom-shim@^1.5.0",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "ts-morph": "npm:ts-morph@^28.0.0",
    "vite": "npm:vite@8.0.10",
    "typescript": "npm:typescript@^5.9.0",
    "tsx": "npm:tsx@^4.21.0",
    "@types/node": "npm:@types/node@^22.0.0",
    "parse5": "npm:parse5@7.0.0",
    "entities": "npm:entities@^4.5.0",
    "@playwright/test": "npm:@playwright/test@^1.52.0"
  },
  "vendor": true,
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "deno run -A npm:vite www --config www/vite.config.ts",
    "build": "cd www && deno run --config ../deno.json -A ../packages/adapter-vite/src/cli/build.ts",
    "preview": "deno run -A npm:vite preview www --config www/vite.config.ts",
    "build:docs": "deno task build",
    "publish:core": "cd packages/core && deno publish",
    "publish:rpc": "cd packages/rpc && deno publish",
    "publish:ui": "cd packages/ui && deno publish",
    "publish:adapter-lit": "cd packages/adapter-lit && deno publish",
    "publish:create": "cd packages/create && deno publish",
    "publish:signals": "cd packages/signals && deno publish",
    "publish:content": "cd packages/content && deno publish",
    "publish:i18n": "cd packages/i18n && deno publish",
    "publish:adapter-vite": "cd packages/adapter-vite && deno publish",
    "publish:app": "cd packages/app && deno publish",
    "publish": "git status --porcelain && deno task publish:rpc && deno task publish:signals && deno task publish:core && deno task publish:adapter-vite && deno task publish:content && deno task publish:i18n && deno task publish:adapter-lit && deno task publish:ui && deno task publish:app && deno task publish:create",
    "publish:dry-run": "deno task publish:rpc --dry-run && deno task publish:signals --dry-run && deno task publish:core --dry-run && deno task publish:adapter-vite --dry-run && deno task publish:content --dry-run && deno task publish:i18n --dry-run && deno task publish:adapter-lit --dry-run && deno task publish:ui --dry-run && deno task publish:app --dry-run && deno task publish:create --dry-run",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "test:coverage": "deno test --coverage=.coverage --allow-read --allow-write --allow-env --allow-net --allow-run && deno coverage .coverage --lcov > .coverage/lcov.info",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --watch",
    "test:e2e": "npx -y @playwright/test test --config www/e2e/playwright.config.ts",
    "test:e2e:install": "npx -y playwright install chromium",
    "typecheck": "deno check **/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "clean": "rm -rf packages/*/dist www/dist",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config core.hooksPath"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports", "no-explicit-any"]
    }
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/node_modules/**",
    ".deno",
    "vendor"
  ]
}
