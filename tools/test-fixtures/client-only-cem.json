{
  "schemaVersion": "1.0.0",
  "packageName": "@test/client-only-wc",
  "version": "1.0.0",
  "readme": "This package has no SSR support declared.",
  "modules": [
    {
      "kind": "javascript-module",
      "path": "./src/client-only.js",
      "declarations": [
        {
          "kind": "custom-element",
          "tagName": "client-only-element",
          "className": "ClientOnlyElement",
          "description": "A client-only web component with no SSR support",
          "attributes": [
            {
              "name": "color",
              "type": "string",
              "defaultValue": "blue"
            }
          ],
          "events": [
            {
              "name": "color-change",
              "type": "CustomEvent<string>"
            }
          ]
        }
      ],
      "exports": [
        {
          "kind": "default",
          "declaration": {
            "name": "ClientOnlyElement"
          }
        }
      ]
    }
  ]
}
