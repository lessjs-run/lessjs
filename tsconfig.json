// Editor-only TypeScript hints for JSX authoring.
// deno.json is the source of truth for build, check, lint, and runtime config.
{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@lessjs/core",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "module": "ESNext"
  }
}
