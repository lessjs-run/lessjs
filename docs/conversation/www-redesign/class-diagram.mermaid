```mermaid
classDiagram
    class DocsHome {
        -_mfaTab: number
        +render() TemplateResult
        -_renderZh() TemplateResult
        -_renderEn() TemplateResult
        +static styles: CSSResult[]
    }
    DocsHome --|> DsdLitElement

    class ShowcaseTab {
        +label: string
        +tag: string
        +tagColor: string
        +islandTag: string
        +code: string
        +codeLabel: string
        +adapterDesc: string
        +installCmd: string
    }
    DocsHome ..> ShowcaseTab : uses

    class LessShowcasePanel {
        -_activeTab: number
        -_tabs: ShowcaseTab[]
        +activeTab: number
        +tabs: ShowcaseTab[]
        +render() TemplateResult
        -_onTabClick(idx) void
    }
    LessShowcasePanel --|> DsdLitElement
    LessShowcasePanel ..> ShowcaseTab : renders

    class LessTermDemo {
        -_abortController: AbortController
        -_cmdHistory: string[]
        -_historyIdx: number
        +render() TemplateResult
        -_focusInput() void
        -_onKey(e: Event) Promise
        -_addLine(htmlStr: string) void
        -_sanitizeTermHtml(html: string) string
        -_localCommands: Record~string, string[]~
    }
    LessTermDemo --|> DsdLitElement

    note for DocsHome "v8 仅改 CSS+模板<br/>接口和数据不变"
```
