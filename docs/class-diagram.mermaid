classDiagram
    direction TB

    %% ─── DsdElement Base Class ───────────────────────────
    class HTMLElement {
        <<browser>>
        +connectedCallback()
        +disconnectedCallback()
        +attributeChangedCallback(name, old, new)
        +attachShadow(init) ShadowRoot
        +getAttribute(name) string
        +setAttribute(name, value)
    }

    class DsdElement {
        <<abstract base>>
        +static styles: CSSStyleSheet | CSSStyleSheet[]
        +static observedAttributes: string[]
        +static hydrateEvents: HydrateEventDescriptor[]
        +static formAssociated: boolean
        +static delegatesFocus: boolean
        #_dsdHydrated: boolean
        #_hydrateAbortController: AbortController
        #_internals: ElementInternals
        +render(): string*
        #createRenderRoot(): ShadowRoot
        #_hydrateEvents(): void
        #_syncDOM(): void
        +layer: ComponentLayer
    }

    HTMLElement <|-- DsdElement : extends

    %% ─── Token Sheet ─────────────────────────────────────
    class openPropsTokenSheet {
        <<CSSStyleSheet singleton>>
        +replaceSync(css: string)
        +cssRules: CSSRuleList
        --spacing tokens
        --typography tokens
        --color tokens (inlined gray scale)
        --effects tokens
        --radius tokens
        --animation tokens
    }

    DsdElement ..> openPropsTokenSheet : "static styles 合并"

    %% ─── Display Components ──────────────────────────────
    class LessCard {
        +static styles = styles
        +render(): string
        +part="container,header,body,footer"
    }

    class LessCallout {
        +static styles = styles
        +render(): string
        +part="container,icon,content"
    }

    class LessStepCard {
        +static styles = styles
        +render(): string
        +part="step,indicator,content"
    }

    DsdElement <|-- LessCard : extends
    DsdElement <|-- LessCallout : extends
    DsdElement <|-- LessStepCard : extends

    %% ─── Attribute-Driven Components ─────────────────────
    class LessButton {
        +static observedAttributes = ['variant','size','disabled','href','target','type']
        +static styles = buttonStyles
        +static delegatesFocus = true
        +static formAssociated = true
        +variant: 'default'|'primary'|'ghost'|'accent'
        +size: 'sm'|'md'|'lg'
        +disabled: boolean
        +href: string|undefined
        +render(): string
        #_syncDOM(): void
        #_updateState(): void
        +part="button"
    }

    class LessInput {
        +static observedAttributes = ['label','value','type','error','placeholder']
        +static styles = inputStyles
        +label: string
        +value: string
        +type: string
        +error: string
        +placeholder: string
        +render(): string
        #_syncDOM(): void
        +part="input,label,error"
    }

    DsdElement <|-- LessButton : extends
    DsdElement <|-- LessInput : extends

    %% ─── Interactive Components ──────────────────────────
    class LessThemeToggle {
        +static hydrateEvents = [{selector, event: 'click', method: '_handleToggle'}]
        +theme: 'light'|'dark'
        +render(): string
        #_handleToggle(): void
        #_updateIcon(): void
        +part="toggle,icon-sun,icon-moon"
    }

    class LessCodeBlock {
        +static hydrateEvents = [{selector, event: 'click', method: '_handleCopy'}]
        +language: string
        +code: string
        +render(): string
        #_handleCopy(): Promise~void~
        #_internals: ElementInternals
        +part="code,copy-button"
    }

    class LessDialog {
        +static hydrateEvents = [{selector,event:'click',method:'_handleClose'},{selector,event:'keydown',method:'_handleKeydown'}]
        +open: boolean
        +label: string
        +render(): string
        #_handleClose(): void
        #_handleKeydown(e: KeyboardEvent): void
        #_trapFocus(): void
        +part="overlay,panel,close,heading,content"
    }

    class LessLayout {
        +static hydrateEvents = [{selector,event:'click',method:'_handleNavClick'},{selector,event:'click',method:'_handleMenuToggle'}]
        +navSections: NavSection[]
        +navLinks: HeaderNavLink[]
        +render(): string
        #_handleNavClick(e: Event): void
        #_handleMenuToggle(): void
        +part="header,sidebar,main,footer,nav"
    }

    DsdElement <|-- LessThemeToggle : extends
    DsdElement <|-- LessCodeBlock : extends
    DsdElement <|-- LessDialog : extends
    DsdElement <|-- LessLayout : extends

    %% ─── Island (保留 Lit) ───────────────────────────────
    class LessHeroPing {
        <<Lit Island - 保留>>
        +extends DsdLitElement
        +render(): TemplateResult
        +part="ping-ring,ping-dot"
    }

    class LessSearch {
        <<app island>>
        +static hydrateEvents = [{selector,event:'input',method:'_handleInput'},{selector,event:'keydown',method:'_handleKeydown'},{selector,event:'click',method:'_handleClick'}]
        +query: string
        +results: SearchResult[]
        +render(): string
        #_handleInput(e: Event): void
        #_handleKeydown(e: KeyboardEvent): void
        #_handleClick(e: Event): void
        +part="overlay,input,results,result-item"
    }

    DsdElement <|-- LessSearch : extends

    %% ─── Core Types ──────────────────────────────────────
    class HydrateEventDescriptor {
        <<interface>>
        +selector: string
        +event: string
        +method: string
    }

    class DsdComponent {
        <<interface>>
        +render(): string|unknown
        +connectedCallback?(): void
        +layer?: ComponentLayer
        +hydrateEvents?: HydrateEventDescriptor[]
        +[key: string]: unknown
    }

    class ComponentLayer {
        <<type>>
        'dsd-static' | 'dsd-interactive' | 'pure-island'
    }

    DsdElement ..|> DsdComponent : implements
    DsdElement --> HydrateEventDescriptor : "static hydrateEvents"
    DsdElement --> ComponentLayer : "layer"

    %% ─── SSR Pipeline ────────────────────────────────────
    class renderDSD {
        <<function>>
        +renderDSD(tagName, componentClass, props, sourceInfo?, dsdOptions?, collector?, nestingDepth?, hooks?): Promise~RenderOutput~
    }

    class RenderOutput {
        <<interface>>
        +html: string
        +errors: RenderError[]
        +metrics: DsdRenderMetrics
        +hydrationHints: HydrationHint[]
    }

    renderDSD ..> DsdElement : "instantiates & calls render()"
    renderDSD ..> RenderOutput : "returns"
