sequenceDiagram
    actor Build as SSG Build (adapter-vite)
    participant RDSD as renderDSD()
    participant Instant as render-instantiate
    participant Comp as DsdElement<br/>component instance
    participant Nest as render-nested
    participant Serial as render-serialize

    %% ─── SSR Render Pipeline ─────────────────────────────────
    rect rgb(240, 248, 255)
        Note over Build,Serial: ═══ SSR Render Pipeline (build time) ═══
    end

    Build->>RDSD: renderDSD('less-button', LessButton, {variant:'primary'})

    RDSD->>RDSD: hooks.beforeRender(input)

    RDSD->>Instant: instantiateComponent('less-button', LessButton)
    Instant->>Comp: new LessButton()
    Comp->>Comp: constructor() - set defaults
    Instant-->>RDSD: instance

    RDSD->>Instant: injectProps(instance, tagName, props)
    Instant->>Comp: instance.variant = 'primary'
    Note over RDSD: Line 173: DO NOT call connectedCallback()

    RDSD->>Comp: instance.render()
    Comp-->>RDSD: `<button class="btn btn--primary"><slot></slot></button>`
    Note over RDSD: Line 177-181: render(): string 直接使用

    RDSD->>Nest: renderNestedCustomElements(content)
    Nest-->>RDSD: { html, errors, hydrationHints }

    rect rgb(255, 250, 240)
        Note over RDSD: ═══ CSSStyleSheet 提取 (NEW - 适配器循环之前) ═══
    end
    RDSD->>RDSD: check componentClass.styles
    alt static styles 是 CSSStyleSheet
        RDSD->>RDSD: 遍历 styles.cssRules, 序列化 cssText
        Note over RDSD: 输出: `.btn { padding:...; border:...; } ...`
    else static styles 是 CSSStyleSheet[]
        RDSD->>RDSD: 遍历数组, 合并所有 cssText
    else 无 styles (回退到适配器)
        RDSD->>RDSD: 继续走 adapter.extractStyles() 逻辑
    end

    rect rgb(240, 255, 240)
        Note over RDSD,Serial: ═══ Serialize ═══
    end

    RDSD->>Serial: wrapDsdOutput({ tagName, props, content, styleCss })
    Serial-->>RDSD: `<less-button variant="primary">`<br/>`  <template shadowrootmode="open">`<br/>`    <style>.btn{...}</style>`<br/>`    <button class="btn btn--primary"><slot></slot></button>`<br/>`  </template>`<br/>`</less-button>`

    RDSD->>RDSD: hooks.afterRender(output)
    RDSD-->>Build: RenderOutput { html, errors, metrics, hydrationHints }

    %% ─── Client Hydration Flow ───────────────────────────────
    rect rgb(255, 245, 238)
        Note over Comp: ═══ Client Hydration (browser runtime) ═══
    end

    Note over Comp: 浏览器解析 DSD HTML，自动创建 Shadow DOM

    Browser->>Comp: customElements.define('less-button', LessButton)
    Browser->>Comp: new LessButton() (升级已有元素)

    Comp->>Comp: createRenderRoot()
    alt shadowRoot 已存在且有子元素 (DSD pre-populated)
        Comp->>Comp: this._dsdHydrated = true
        Comp-->>Browser: return this.shadowRoot (复用)
    else 无 shadowRoot (JS 动态创建)
        Comp-->>Browser: return this.attachShadow({ mode: 'open' })
    end

    Browser->>Comp: connectedCallback()
    alt this._dsdHydrated === true
        Comp->>Comp: _hydrateEvents()
        loop 每个 hydrateEvent descriptor
            Comp->>Comp: shadowRoot.querySelectorAll(selector)
            Comp->>Comp: el.addEventListener(event, handler, { signal })
            Note over Comp: 使用 AbortController 实现自动清理
        end
        Note over Comp: 无需调用 render() — DSD DOM 已就绪
    else _dsdHydrated === false
        Comp->>Comp: this.render()
        Note over Comp: 首次渲染（JS 动态创建场景）
    end

    Note over Comp: 组件就绪，事件已绑定

    opt 属性变更
        Browser->>Comp: setAttribute('disabled', '')
        Comp->>Comp: attributeChangedCallback('disabled', null, '')
        Comp->>Comp: this.disabled = true
        Comp->>Comp: _syncDOM()
        Comp->>Comp: _updateState() (ElementInternals)
    end

    opt 组件销毁
        Browser->>Comp: disconnectedCallback()
        Comp->>Comp: _hydrateAbortController.abort()
        Note over Comp: 所有事件监听器自动移除
    end
