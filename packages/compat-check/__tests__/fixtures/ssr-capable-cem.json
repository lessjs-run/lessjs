{
  "schemaVersion": "1.0.0",
  "packageName": "@test/ssr-capable-wc",
  "version": "1.0.0",
  "modules": [
    {
      "kind": "javascript-module",
      "path": "./src/my-element.js",
      "declarations": [
        {
          "kind": "custom-element",
          "tagName": "ssr-capable-element",
          "className": "MyElement",
          "superClass": {
            "name": "LitElement"
          },
          "attributes": [
            {
              "name": "variant",
              "type": "string",
              "defaultValue": "primary"
            }
          ],
          "events": [
            {
              "name": "my-event",
              "type": "CustomEvent"
            }
          ],
          "slots": [
            {
              "name": ""
            }
          ],
          "openElement": {
            "ssr": true,
            "dsd": true,
            "hydrate": "load",
            "layer": "dsd-interactive"
          }
        }
      ],
      "exports": [
        {
          "kind": "default",
          "declaration": {
            "name": "MyElement"
          }
        }
      ]
    }
  ]
}
