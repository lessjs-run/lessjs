{
  "name": "@lessjs/content",
  "version": "0.30.0",
  "exports": {
    ".": "./src/index.ts",
    "./blog-data": "./src/blog/blog-data.ts",
    "./mdx": "./src/mdx/index.ts",
    "./nav": "./src/nav/index.ts",
    "./nav-data": "./src/nav/writer.ts",
    "./sitemap": "./src/sitemap/index.ts"
  },
  "imports": {
    "marked": "npm:marked@^15",
    "gray-matter": "npm:gray-matter@^4.0.3",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@^3.1.1",
    "section-matter": "npm:section-matter@^1.0.0",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.29.0/logger",
    "@lessjs/protocols/build-types": "jsr:@lessjs/protocols@^0.29.0/build-types",
    "vite": "npm:vite@8.0.10"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
