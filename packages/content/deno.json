{
  "name": "@lessjs/content",
  "version": "0.24.2",
  "exports": {
    ".": "./src/index.ts",
    "./blog-data": "./src/blog/blog-data.ts",
    "./nav": "./src/nav/index.ts",
    "./sitemap": "./src/sitemap/index.ts"
  },
  "imports": {
    "marked": "npm:marked@^15",
    "gray-matter": "npm:gray-matter@^4.0.3",
    "section-matter": "npm:section-matter@^1.0.0",
    "sanitize-html": "npm:sanitize-html@^2.17.4",
    "@types/sanitize-html": "npm:@types/sanitize-html@^2",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.24.2/logger",
    "@lessjs/protocols/build-types": "jsr:@lessjs/protocols@^0.24.2/build-types",
    "@lessjs/protocols/virtual-ids": "jsr:@lessjs/protocols@^0.24.2/virtual-ids",
    "vite": "npm:vite@8.0.10"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
