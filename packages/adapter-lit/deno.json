{
  "name": "@lessjs/adapter-lit",
  "version": "0.6.3",
  "exports": {
    ".": "./src/index.ts",
    "./ssr": "./src/ssr.ts",
    "./ssr.js": "./src/ssr.ts",
    "./dsd-hydration": "./src/dsd-hydration.ts",
    "./dsd-hydration.js": "./src/dsd-hydration.ts"
  },
  "imports": {
    "@lessjs/core/render-dsd": "jsr:@lessjs/core@^0.7.0/render-dsd",
    "@lessjs/core/less-runtime": "jsr:@lessjs/core@^0.7.0/less-runtime"
  },
  "tasks": {
    "build": "deno check src/index.ts src/ssr.ts src/dsd-hydration.ts"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
