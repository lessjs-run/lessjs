{
  "name": "@lessjs/adapter-lit",
  "version": "0.24.3",
  "exports": {
    ".": "./src/index.ts",
    "./ssr": "./src/ssr.ts",
    "./dsd-hydration": "./src/dsd-hydration.ts"
  },
  "imports": {
    "@lessjs/core": "jsr:@lessjs/core@^0.24.3",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.24.3/logger"
  },
  "tasks": {
    "build": "deno check src/index.ts src/ssr.ts src/dsd-hydration.ts"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
