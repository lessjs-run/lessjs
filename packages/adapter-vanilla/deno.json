{
  "name": "@openelement/adapter-vanilla",
  "version": "0.30.1",
  "exports": {
    ".": "./src/index.ts",
    "./ssr": "./src/ssr.ts",
    "./dsd-hydration": "./src/dsd-hydration.ts"
  },
  "imports": {
    "@openelement/core": "jsr:@openelement/core@^0.30.1",
    "@openelement/core/logger": "jsr:@openelement/core@^0.30.1/logger"
  },
  "tasks": {
    "build": "deno check src/index.ts src/ssr.ts src/dsd-hydration.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
