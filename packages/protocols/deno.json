{
  "name": "@lessjs/protocols",
  "version": "0.22.1",
  "exports": {
    ".": "./src/index.ts",
    "./build-types": "./src/build-types.ts",
    "./virtual-ids": "./src/virtual-ids.ts"
  },
  "imports": {},
  "tasks": {
    "build": "deno check src/index.ts"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
