{
  "name": "@openelement/app",
  "version": "0.40.0",
  "exports": {
    ".": "./src/index.ts",
    "./i18n": "./src/i18n.ts",
    "./i18n-plugin": "./src/i18n-plugin.ts",
    "./preact": "./src/preact.ts",
    "./vite": "./src/vite.ts"
  },
  "imports": {
    "@openelement/core": "jsr:@openelement/core@^0.40.0",
    "@openelement/core/logger": "jsr:@openelement/core@^0.40.0/logger",
    "@openelement/element": "jsr:@openelement/element@^0.40.0",
    "@openelement/protocol": "jsr:@openelement/protocol@^0.40.0",
    "@openelement/protocol/islands": "jsr:@openelement/protocol@^0.40.0/islands",
    "@openelement/protocol/data": "jsr:@openelement/protocol@^0.40.0/data",
    "@openelement/router": "jsr:@openelement/router@^0.40.0",
    "@openelement/adapter-vite": "jsr:@openelement/adapter-vite@^0.40.0",
    "@openelement/content": "jsr:@openelement/content@^0.40.0",
    "preact": "npm:preact@^10.28.0",
    "preact-render-to-string": "npm:preact-render-to-string@^6.5.0",
    "vite": "npm:vite@8.0.10"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "tasks": {
    "build": "deno check src/index.ts"
