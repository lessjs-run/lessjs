{
  "name": "@lessjs/core",
  "version": "0.12.0",
  "exports": {
    ".": "./src/index.ts",
    "./render-dsd": "./src/render-dsd.ts",
    "./render-dsd.js": "./src/render-dsd.ts",
    "./html-escape": "./src/html-escape.ts",
    "./html-escape.js": "./src/html-escape.ts",
    "./render-nested": "./src/render-nested.ts",
    "./render-nested.js": "./src/render-nested.ts",
    "./adapter-registry": "./src/adapter-registry.ts",
    "./adapter-registry.js": "./src/adapter-registry.ts",
    "./ssr-handler": "./src/ssr-handler.ts",
    "./ssr-handler.js": "./src/ssr-handler.ts",
    "./errors": "./src/errors.ts",
    "./context": "./src/context.ts",
    "./logger": "./src/logger.ts",
    "./logger.js": "./src/logger.ts",
    "./navigation": "./src/navigation.ts",
    "./navigation.js": "./src/navigation.ts",
    "./constants": "./src/constants.ts"
  },
  "imports": {
    "parse5": "npm:parse5@7.0.0"
  },
  "tasks": {
    "build": "deno check src/index.ts src/render-dsd.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
