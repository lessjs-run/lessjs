{
  "name": "@openelement/core",
  "version": "0.40.0",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./context": "./src/context.ts",
    "./logger": "./src/logger.ts",
    "./isr": "./src/isr.ts",
    "./isr-runtime": "./src/isr-runtime.ts",
    "./signal-context": "./src/signal-context.ts",
    "./render-dsd-stream": "./src/render-dsd-stream.ts",
    "./open-element": "./src/open-element.ts",
    "./style-sheet": "./src/style-sheet.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts",
    "./island-transform": "./src/island-transform.ts",
    "./data": "./src/data.ts",
    "./dsd-hydration": "./src/dsd-hydration.ts"
  },
  "imports": {
    "@openelement/protocol/conformance": "jsr:@openelement/protocol@^0.40.0/conformance",
    "@openelement/protocol/data": "jsr:@openelement/protocol@^0.40.0/data",
    "@openelement/protocol/renderer": "jsr:@openelement/protocol@^0.40.0/renderer",
    "@openelement/protocol/signals": "jsr:@openelement/protocol@^0.40.0/signals",
    "@openelement/signal": "jsr:@openelement/signal@^0.40.0"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "lint": "deno lint src/ __tests__/",
    "typecheck": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run __tests__/",
    "test:ci": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --coverage --junit-path=test-results.xml __tests__/"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
