{
  "name": "@lessjs/core",
  "version": "0.21.10",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./context": "./src/context.ts",
    "./logger": "./src/logger.ts",
    "./style-sheet": "./src/style-sheet.ts",
    "./api": "./src/api.ts",
    "./isr": "./src/isr.ts",
    "./navigation": "./src/navigation.ts",
    "./build-types": "./src/build-types.ts",
    "./virtual-ids": "./src/virtual-ids.ts",
    "./render-serialize": "./src/render-serialize.ts",
    "./render-instantiate": "./src/render-instantiate.ts",
    "./render-errors": "./src/render-errors.ts",
    "./render-dsd-stream": "./src/render-dsd-stream.ts",
    "./cem-parser": "./src/cem-parser.ts",
    "./compatibility": "./src/compatibility.ts",
    "./types": "./src/types.ts",
    "./validate-manifest": "./src/validate-manifest.ts",
    "./cli/validate-manifest": "./src/cli/validate-manifest.ts",
    "./less-add": "./src/less-add.ts",
    "./cli/less-add": "./src/cli/less-add.ts",
    "./dom-simulation": "./src/dom-simulation.ts"
  },
  "imports": {
    "parse5": "npm:parse5@7.0.0",
    "@lessjs/signals": "jsr:@lessjs/signals@^0.21.9",
    "@lessjs/signals/framework": "jsr:@lessjs/signals@^0.21.9/framework"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "tasks": {
    "build": "deno check src/index.ts src/render-dsd.ts",
    "lint": "deno lint src/ __tests__/",
    "typecheck": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run __tests__/",
    "test:ci": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --coverage --junit-path=test-results.xml __tests__/"
  }
}
