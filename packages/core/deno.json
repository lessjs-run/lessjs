{
  "name": "@lessjs/core",
  "version": "0.9.0",
  "exports": {
    ".": "./src/index.ts",
    "./render-dsd": "./src/render-dsd.ts",
    "./render-dsd.js": "./src/render-dsd.ts",
    "./html-escape": "./src/html-escape.ts",
    "./html-escape.js": "./src/html-escape.ts",
    "./render-nested": "./src/render-nested.ts",
    "./render-nested.js": "./src/render-nested.ts",
    "./island-manifest": "./src/island-manifest.ts",
    "./island-manifest.js": "./src/island-manifest.ts",
    "./less-runtime": "./src/less-runtime.ts",
    "./less-runtime.js": "./src/less-runtime.ts",
    "./logger": "./src/logger.ts",
    "./logger.js": "./src/logger.ts",
    "./cli/build": "./src/cli/build.ts",
    "./cli/build-client": "./src/cli/build-client.ts",
    "./cli/build-ssg": "./src/cli/build-ssg.ts"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts src/render-dsd.ts src/less-runtime.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
