{
  "name": "@lessjs/core",
  "version": "0.14.11",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./context": "./src/context.ts",
    "./logger": "./src/logger.ts",
    "./navigation": "./src/navigation.ts",
    "./build-types": "./src/build-types.ts",
    "./virtual-ids": "./src/virtual-ids.ts",
    "./render-serialize": "./src/render-serialize.ts",
    "./render-instantiate": "./src/render-instantiate.ts",
    "./render-errors": "./src/render-errors.ts"
  },
  "imports": {
    "parse5": "npm:parse5@7.0.0"
  },
  "tasks": {
    "build": "deno check src/index.ts src/render-dsd.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
