{
  "name": "@openelement/signal",
  "version": "0.40.0",
  "exports": {
    ".": "./src/index.ts",
    "./framework": "./src/framework.ts",
    "./alien-engine": "./src/alien-engine.ts",
    "./preact-engine": "./src/preact-engine.ts"
  },
  "imports": {
    "@openelement/protocol/signals": "jsr:@openelement/protocol@^0.40.0/signals",
    "@preact/signals-core": "npm:@preact/signals-core@^1.12.1",
    "alien-signals": "npm:alien-signals@^3.2.0"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "tasks": {
    "build": "deno check src/index.ts"
  }
}
