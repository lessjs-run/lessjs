{
  "name": "@kissjs/ui",
  "version": "0.3.6",
  "description": "KISS UI — Swiss International Style component library built on Lit + design tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kiss-button": {
      "types": "./dist/kiss-button.d.ts",
      "import": "./dist/kiss-button.js"
    },
    "./kiss-card": {
      "types": "./dist/kiss-card.d.ts",
      "import": "./dist/kiss-card.js"
    },
    "./kiss-input": {
      "types": "./dist/kiss-input.d.ts",
      "import": "./dist/kiss-input.js"
    },
    "./kiss-code-block": {
      "types": "./dist/kiss-code-block.d.ts",
      "import": "./dist/kiss-code-block.js"
    },
    "./kiss-layout": {
      "types": "./dist/kiss-layout.d.ts",
      "import": "./dist/kiss-layout.js"
    },
    "./kiss-theme-toggle": {
      "types": "./dist/kiss-theme-toggle.d.ts",
      "import": "./dist/kiss-theme-toggle.js"
    },
    "./kiss-hero-ping": {
      "types": "./dist/kiss-hero-ping.d.ts",
      "import": "./dist/kiss-hero-ping.js"
    },
    "./kiss-ui-plugin": {
      "types": "./dist/kiss-ui-plugin.d.ts",
      "import": "./dist/kiss-ui-plugin.js"
    },
    "./design-tokens": {
      "types": "./dist/design-tokens.d.ts",
      "import": "./dist/design-tokens.js"
    },
    "./tokens/colors": {
      "types": "./dist/tokens/colors.d.ts",
      "import": "./dist/tokens/colors.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build --config vite.config.build.ts",
    "dev": "vite build --config vite.config.build.ts --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@kissjs/core": "^0.3.1",
    "lit": "^3.2.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "vite": "^6.3.0",
    "@types/node": "^22.0.0"
  }
}
