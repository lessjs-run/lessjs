{
  "name": "@kissjs/ui",
  "version": "0.3.6",
  "exports": {
    ".": "./dist/index.js",
    "./kiss-button": "./dist/kiss-button.js",
    "./kiss-card": "./dist/kiss-card.js",
    "./kiss-input": "./dist/kiss-input.js",
    "./kiss-code-block": "./dist/kiss-code-block.js",
    "./kiss-layout": "./dist/kiss-layout.js",
    "./kiss-theme-toggle": "./dist/kiss-theme-toggle.js",
    "./kiss-hero-ping": "./dist/kiss-hero-ping.js",
    "./kiss-ui-plugin": "./dist/kiss-ui-plugin.js",
    "./design-tokens": "./dist/design-tokens.js",
    "./tokens/colors": "./dist/tokens/colors.js"
  },
  "tasks": {
    "build": "deno run -A npm:vite build --config vite.config.build.ts",
    "dev": "deno run -A npm:vite build --config vite.config.build.ts --watch"
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "imports": {
    "lit": "npm:lit@^3.2.0"
  },
  "publish": {
    "include": ["dist/**", "deno.json", "jsr.json", "LICENSE"],
    "exclude": ["!dist", "node_modules", "src"]
  }
}
