{
  "name": "@lessjs/rpc",
  "version": "0.3.1",
  "exports": {
    ".": "./src/index.ts"
  },
  "tasks": {
    "build": "deno run -A npm:vite build --config vite.config.build.ts",
    "dev": "deno run -A npm:vite build --config vite.config.build.ts --watch"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
