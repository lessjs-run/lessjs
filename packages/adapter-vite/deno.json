{
  "name": "@openelement/adapter-vite",
  "version": "0.40.0",
  "exports": {
    ".": "./src/index.ts",
    "./build-context": "./src/build-context.ts",
    "./head-injection": "./src/head-injection.ts",
    "./nitro-mount": "./src/nitro-mount.ts",
    "./plugin": "./src/plugin.ts",
    "./subpath-resolver": "./src/subpath-resolver.ts",
    "./optional-package-stubs": "./src/optional-package-stubs.ts",
    "./plugin-mdx": "./src/plugin-mdx.ts",
    "./cli/build": "./src/cli/build.ts",
    "./cli/build-client": "./src/cli/build-client.ts",
    "./cli/build-ssg": "./src/cli/build-ssg.ts"
  },
  "imports": {
    "@openelement/core": "jsr:@openelement/core@^0.40.0",
    "@openelement/core/logger": "jsr:@openelement/core@^0.40.0/logger",
    "@openelement/core/errors": "jsr:@openelement/core@^0.40.0/errors",
    "@openelement/core/context": "jsr:@openelement/core@^0.40.0/context",
    "@openelement/protocols/build-types": "jsr:@openelement/protocols@^0.40.0/build-types",
    "@openelement/protocols/routes": "jsr:@openelement/protocols@^0.40.0/routes",
    "@openelement/protocols/runtime": "jsr:@openelement/protocols@^0.40.0/runtime",
    "@openelement/content/sitemap": "jsr:@openelement/content@^0.40.0/sitemap",
    "@openelement/core/style-sheet": "jsr:@openelement/core@^0.40.0/style-sheet",
    "@mdx-js/rollup": "npm:@mdx-js/rollup@^3.1.1",
    "typescript": "npm:typescript@^5.9.0",
    "esbuild": "npm:esbuild@^0.25",
    "hono": "npm:hono@^4.12",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
