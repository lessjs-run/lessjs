{
  "name": "@lessjs/adapter-vite",
  "version": "0.23.1",
  "exports": {
    ".": "./src/index.ts",
    "./build-context": "./src/build-context.ts",
    "./head-injection": "./src/head-injection.ts",
    "./less-plugin": "./src/less-plugin.ts",
    "./subpath-resolver": "./src/subpath-resolver.ts",
    "./optional-package-stubs": "./src/optional-package-stubs.ts",
    "./phase-context": "./src/phase-context.ts",
    "./cli/build": "./src/cli/build.ts",
    "./cli/build-client": "./src/cli/build-client.ts",
    "./cli/build-ssg": "./src/cli/build-ssg.ts"
  },
  "imports": {
    "@lessjs/core": "jsr:@lessjs/core@^0.23.0",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.23.0/logger",
    "@lessjs/core/errors": "jsr:@lessjs/core@^0.23.0/errors",
    "@lessjs/core/context": "jsr:@lessjs/core@^0.23.0/context",
    "@lessjs/core/navigation": "jsr:@lessjs/core@^0.23.0/navigation",
    "@lessjs/protocols/build-types": "jsr:@lessjs/protocols@^0.23.0/build-types",
    "@lessjs/protocols/virtual-ids": "jsr:@lessjs/protocols@^0.23.0/virtual-ids",
    "@lessjs/cem": "jsr:@lessjs/cem@^0.23.0",
    "@lessjs/compat-check": "jsr:@lessjs/compat-check@^0.23.0",
    "@lessjs/content/sitemap": "jsr:@lessjs/content@^0.23.0/sitemap",
    "@lessjs/style-sheet": "jsr:@lessjs/style-sheet@^0.23.0",
    "esbuild": "npm:esbuild@^0.25",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
