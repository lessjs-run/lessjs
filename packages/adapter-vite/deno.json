{
  "name": "@lessjs/adapter-vite",
  "version": "0.14.0",
  "exports": {
    ".": "./src/index.ts",
    "./build-context": "./src/build-context.ts",
    "./virtual-ids": "./src/virtual-ids.ts"
  },
  "imports": {
    "@lessjs/core": "jsr:@lessjs/core@^0.14",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.14/logger",
    "@lessjs/core/errors": "jsr:@lessjs/core@^0.14/errors",
    "@lessjs/core/context": "jsr:@lessjs/core@^0.14/context",
    "@lessjs/core/navigation": "jsr:@lessjs/core@^0.14/navigation",
    "esbuild": "npm:esbuild@^0.25",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
