{
  "name": "@lessjs/adapter-vite",
  "version": "0.2.0",
  "exports": {
    ".": "./src/index.ts",
    "./build-context": "./src/build-context.ts"
  },
  "imports": {
    "@lessjs/core": "jsr:@lessjs/core@^0.12",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.12/logger",
    "@lessjs/core/errors": "jsr:@lessjs/core@^0.12/errors",
    "@lessjs/core/context": "jsr:@lessjs/core@^0.12/context",
    "@lessjs/core/render-dsd": "jsr:@lessjs/core@^0.12/render-dsd",
    "@lessjs/core/html-escape": "jsr:@lessjs/core@^0.12/html-escape",
    "@lessjs/core/adapter-registry": "jsr:@lessjs/core@^0.12/adapter-registry",
    "@lessjs/core/ssr-handler": "jsr:@lessjs/core@^0.12/ssr-handler",
    "@lessjs/core/navigation": "jsr:@lessjs/core@^0.12/navigation",
    "esbuild": "npm:esbuild@^0.25",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": ["src/**", "deno.json", "LICENSE"]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
