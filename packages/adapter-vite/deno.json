{
  "name": "@lessjs/adapter-vite",
  "version": "0.20.0",
  "exports": {
    ".": "./src/index.ts",
    "./build-context": "./src/build-context.ts",
    "./virtual-ids": "./src/virtual-ids.ts",
    "./cli/build": "./src/cli/build.ts",
    "./cli/build-client": "./src/cli/build-client.ts",
    "./cli/build-ssg": "./src/cli/build-ssg.ts"
  },
  "imports": {
    "@lessjs/core": "jsr:@lessjs/core@^0.20.0",
    "@lessjs/core/logger": "jsr:@lessjs/core@^0.20.0/logger",
    "@lessjs/core/errors": "jsr:@lessjs/core@^0.20.0/errors",
    "@lessjs/core/context": "jsr:@lessjs/core@^0.20.0/context",
    "@lessjs/core/navigation": "jsr:@lessjs/core@^0.20.0/navigation",
    "@lessjs/core/build-types": "jsr:@lessjs/core@^0.20.0/build-types",
    "@lessjs/core/virtual-ids": "jsr:@lessjs/core@^0.20.0/virtual-ids",
    "esbuild": "npm:esbuild@^0.25",
    "hono": "npm:hono@^4",
    "@hono/vite-dev-server": "npm:@hono/vite-dev-server@^0.25.3",
    "vite": "npm:vite@8.0.10"
  },
  "tasks": {
    "build": "deno check src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net __tests__/"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
