{
  "name": "@openelement/signals",
  "version": "0.38.0",
  "exports": {
    ".": "./src/index.ts",
    "./framework": "./src/framework.ts",
    "./alien-engine": "./src/alien-engine.ts"
  },
  "imports": {
    "@openelement/protocols/signals": "jsr:@openelement/protocols@^0.38.0/signals",
    "alien-signals": "npm:alien-signals@^3.2.0"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "tasks": {
    "build": "deno check src/index.ts"
  }
}
