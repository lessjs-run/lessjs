{
  "name": "@lessjs/signals",
  "version": "0.21.7",
  "exports": {
    ".": "./src/index.ts",
    "./framework": "./src/framework.ts"
  },
  "publish": {
    "include": [
      "src/**",
      "deno.json",
      "README.md",
      "LICENSE"
    ]
  },
  "compilerOptions": {
    "skipLibCheck": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
